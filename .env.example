# build.nvidia.com で取得した NGC API key
NGC_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Langfuse self-hosted の API key（Ch 10 以降で利用）
# Langfuse の project 作成後に発行される
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Langfuse self-hosted のホスト（compose 内 service 名で参照可）
LANGFUSE_HOST=http://langfuse-web:3000
