# Langfuse v3 self-hosted のシークレット（生成手順）
#
# 以下を実行して .env を作成すれば、安全な乱数で全 secret が埋まる:
#
#   {
#     echo "ENCRYPTION_KEY=$(openssl rand -hex 32)"
#     echo "SALT=$(openssl rand -hex 16)"
#     echo "NEXTAUTH_SECRET=$(openssl rand -hex 32)"
#     echo "REDIS_AUTH=$(openssl rand -hex 16)"
#     echo "CLICKHOUSE_PASSWORD=$(openssl rand -hex 16)"
#     SK=$(openssl rand -hex 16)
#     echo "MINIO_ROOT_PASSWORD=$SK"
#     echo "LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=$SK"
#     echo "LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=$SK"
#     echo "LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=$SK"
#   } > .env
#
# ★ MINIO_ROOT_PASSWORD と LANGFUSE_S3_*_SECRET_ACCESS_KEY は同じ値にすること

ENCRYPTION_KEY=<openssl rand -hex 32>
SALT=<openssl rand -hex 16>
NEXTAUTH_SECRET=<openssl rand -hex 32>
REDIS_AUTH=<openssl rand -hex 16>
CLICKHOUSE_PASSWORD=<openssl rand -hex 16>
MINIO_ROOT_PASSWORD=<openssl rand -hex 16>
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=<MINIO_ROOT_PASSWORD と同値>
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=<同上>
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=<同上>

# 自動ブートストラップ（任意、初回起動時のみ反映）
LANGFUSE_INIT_ORG_ID=poc-org
LANGFUSE_INIT_ORG_NAME=PoC Org
LANGFUSE_INIT_PROJECT_ID=poc-project
LANGFUSE_INIT_PROJECT_NAME=NAT Production Ops PoC
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-poc-public-XXXX
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-poc-secret-YYYY
LANGFUSE_INIT_USER_EMAIL=poc@example.local
LANGFUSE_INIT_USER_NAME=PoC User
LANGFUSE_INIT_USER_PASSWORD=<安全なパスワード>
